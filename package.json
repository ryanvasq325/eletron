{
  "name": "eletron",
  "version": "1.0.0",
  "description": "testando",
  "homepage": "https://github.com/ryanvasq325/eletron#readme",
  "bugs": {
    "url": "https://github.com/ryanvasq325/eletron/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanvasq325/eletron.git"
  },
  "license": "ISC",
  "author": "ryanvasq325 <ryanvasques77@gmail.com>",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ryan.eletron",
    "productName": "Inventario TI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Inventario TI"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/@electron-forge/*"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "electron-squirrel-startup": "^1.0.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.8"
  }
}
