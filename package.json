{
  "name": "inventario-ti-4bpm",
  "version": "1.0.3",
  "description": "Inventário e Controle de Equipamentos de TI — 4º BPM Cacoal/RO",
  "homepage": "https://github.com/ryanvasq325/eletron#readme",
  "bugs": {
    "url": "https://github.com/ryanvasq325/eletron/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanvasq325/eletron.git"
  },
  "license": "ISC",
  "author": "ryanvasq325 <ryanvasques77@gmail.com>",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.nti.inventario4bpm",
    "productName": "Inventario TI 4BPM",
    "publish": {
      "provider": "github",
      "owner": "ryanvasq325",
      "repo": "eletron",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Inventario TI 4BPM",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**",
      "!*.md",
      "!node_modules/@electron-forge/**"
    ],
    "extraResources": [],
    "asar": true
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}